APP_ENV=development
DATABASE_URL=sqlite:///./pollisync.db
FRONTEND_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
SECRET_KEY=replace-this-before-deployment
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# Firebase — choose ONE of the three options below:
# Option 1 (recommended for cloud deploy): paste the full service account JSON as a single-line string
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option 2: individual key fields (alternative to JSON string)
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
# Option 3: path to service account JSON file (local dev only)
FIREBASE_SERVICE_ACCOUNT_PATH=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash

# Supabase (production database)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

EE_SERVICE_ACCOUNT=
EE_PRIVATE_KEY_FILE=

# ML model artifacts — absolute path to the folder containing .pkl files
# Leave blank to use the default ../ml/models path relative to the repo root
MODELS_DIR=
